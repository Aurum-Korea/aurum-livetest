{
  "buildCommand": null,
  "outputDirectory": ".",
  "framework": null,
  "cleanUrls": true,
  "trailingSlash": false,
  "functions": {
    "api/doc.js": {
      "includeFiles": "_docs/**,_pages/**"
    },
    "api/nda.js": {
      "includeFiles": "_docs/**"
    }
  },
  "rewrites": [
    {
      "source": "/api/public",
      "destination": "/api/v2?resource=public&op=stats"
    },
    {
      "source": "/api/advisor/setup",
      "destination": "/api/v2?resource=advisor&op=setup"
    },
    {
      "source": "/api/advisors/list",
      "destination": "/api/v2?resource=advisors&op=list"
    },
    {
      "source": "/api/admin/approve",
      "destination": "/api/v2?resource=admin&op=approve"
    },
    {
      "source": "/api/deals/list",
      "destination": "/api/v2?resource=deals"
    },
    {
      "source": "/api/deals/create",
      "destination": "/api/v2?resource=deals"
    },
    {
      "source": "/api/deals/update",
      "destination": "/api/v2?resource=deals"
    },
    {
      "source": "/api/deals/seed",
      "destination": "/api/v2?resource=deals&op=seed"
    },
    {
      "source": "/api/advisor/login",
      "destination": "/api/v2?resource=advisor&op=login"
    },
    {
      "source": "/api/advisor/logout",
      "destination": "/api/v2?resource=advisor&op=logout"
    },
    {
      "source": "/api/advisor/me",
      "destination": "/api/v2?resource=advisor&op=me"
    },
    {
      "source": "/api/advisor/deals",
      "destination": "/api/v2?resource=advisor&op=deals"
    },
    {
      "source": "/api/advisor/create",
      "destination": "/api/v2?resource=advisor&op=create"
    },
    {
      "source": "/api/advisor/seed",
      "destination": "/api/v2?resource=advisor&op=seed"
    },
    {
      "source": "/api/member/me",
      "destination": "/api/v2?resource=member&op=me"
    },
    {
      "source": "/advisor",
      "destination": "/advisor.html"
    },
    {
      "source": "/_docs/(.*)",
      "destination": "/404"
    },
    {
      "source": "/_pages/(.*)",
      "destination": "/404"
    },
    {
      "source": "/api/_lib/(.*)",
      "destination": "/404"
    },
    {
      "source": "/main",
      "destination": "/api/doc?id=program-page"
    },
    {
      "source": "/memo",
      "destination": "/api/doc?id=memo-page"
    },
    {
      "source": "/portfolio",
      "destination": "/portfolio.html"
    },
    {
      "source": "/nda",
      "destination": "/api/doc?id=nda-page"
    },
    {
      "source": "/ioi",
      "destination": "/api/doc?id=ioi-page"
    },
    {
      "source": "/api/nda-template",
      "destination": "/api/nda?op=template"
    },
    {
      "source": "/api/nda-upload",
      "destination": "/api/nda?op=upload"
    },
    {
      "source": "/api/nda-status",
      "destination": "/api/nda?op=status"
    },
    {
      "source": "/api/admin/nda-review",
      "destination": "/api/admin/nda?op=review"
    },
    {
      "source": "/api/admin/nda-download",
      "destination": "/api/admin/nda?op=download"
    },
    {
      "source": "/api/admin/nda-archive",
      "destination": "/api/admin/nda?op=archive"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Frame-Options",
          "value": "SAMEORIGIN"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(), microphone=(), geolocation=()"
        }
      ]
    },
    {
      "source": "/main",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store"
        },
        {
          "key": "X-Robots-Tag",
          "value": "noindex, nofollow"
        }
      ]
    },
    {
      "source": "/admin",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store"
        },
